<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#080C14</color>
    <color name="black">#000000</color>
    <color name="divider">#1E2A3A</color>
    <color name="error">#FF4444</color>
    <color name="on_primary">#000000</color>
    <color name="on_secondary">#FFFFFF</color>
    <color name="on_surface">#F1F5F9</color>
    <color name="on_surface_muted">#64748B</color>
    <color name="primary">#00D4AA</color>
    <color name="primary_variant">#00A885</color>
    <color name="secondary">#FF6B35</color>
    <color name="secondary_variant">#CC5528</color>
    <color name="status_bar">#080C14</color>
    <color name="success">#00D4AA</color>
    <color name="surface">#111827</color>
    <color name="surface_variant">#1E2A3A</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">Video Generator</string>
    <style name="BottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_tint</item>
        <item name="itemTextColor">@color/bottom_nav_tint</item>
        <item name="itemRippleColor">@color/primary</item>
        <item name="elevation">8dp</item>
    </style>
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_variant</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="Theme.VideoGenerator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_surface</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialCardViewStyle">@style/CardStyle</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
        <item name="toolbarStyle">@style/ToolbarStyle</item>
    </style>
    <style name="ToolbarStyle" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="titleTextColor">@color/on_surface</item>
    </style>
</resources>